{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "HTTP Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(bluerbook_http_requests_total{}[$__rate_interval]))",
          "legendFormat": "{{status_code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum by (route) (rate(bluerbook_http_requests_total{route=~\"/api/.*\"}[$__rate_interval]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Recipes",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "title": "Recipe Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum by (operation) (rate(bluerbook_recipe_operations_total{}[$__rate_interval]))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Meal Plan Changes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "expr": "sum by (action) (rate(bluerbook_meal_plan_changes_total{}[$__rate_interval]))",
          "legendFormat": "{{action}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Search Result Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "sum(increase(bluerbook_recipe_search_results_bucket{}[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "title": "Recipe Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "sum by (operation) (rate(bluerbook_recipe_errors_total{}[$__rate_interval]))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "title": "Chat / LLM",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "title": "Chat Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "targets": [
        {
          "expr": "rate(bluerbook_chat_sessions_created_total{}[$__rate_interval])",
          "legendFormat": "sessions"
        },
        {
          "expr": "rate(bluerbook_chat_messages_total{}[$__rate_interval])",
          "legendFormat": "messages"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Chat Response Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(bluerbook_chat_response_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(bluerbook_chat_response_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Stream Parts per Response",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(bluerbook_chat_response_stream_parts_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(bluerbook_chat_response_stream_parts_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Chat Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 35 },
      "targets": [
        {
          "expr": "increase(bluerbook_chat_errors_total{}[1h])",
          "legendFormat": "errors (1h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["bluer-book"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "The Bluer Book",
  "uid": "bluer-book"
}
