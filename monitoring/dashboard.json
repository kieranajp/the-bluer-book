{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "id": null,
  "uid": "bluer-book",
  "title": "The Bluer Book",
  "tags": ["bluer-book", "api"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Request Rate",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{
        "expr": "sum(rate(bluerbook_http_requests_total{route!=\"/metrics\"}[$__rate_interval]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "targets": [{
        "expr": "sum(rate(bluerbook_http_requests_total{status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(bluerbook_http_requests_total{}[$__rate_interval])), 1)",
        "legendFormat": "error %"
      }]
    },
    {
      "title": "p50 / p95 / p99 Latency",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 8, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Recipes Created",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{
        "expr": "increase(bluerbook_recipe_operations_total{operation=\"created\"}[$__rate_interval])",
        "legendFormat": "created"
      }]
    },
    {
      "title": "Chat Sessions",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "targets": [{
        "expr": "increase(bluerbook_chat_sessions_created_total{}[$__rate_interval])",
        "legendFormat": "sessions"
      }]
    },

    {
      "title": "HTTP Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Request Rate by Status",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (status_code) (rate(bluerbook_http_requests_total{route!=\"/metrics\"}[$__rate_interval]))",
        "legendFormat": "{{status_code}}"
      }]
    },
    {
      "title": "Request Rate by Route",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (route, method) (rate(bluerbook_http_requests_total{route=~\"/api/.*\"}[$__rate_interval]))",
        "legendFormat": "{{method}} {{route}}"
      }]
    },
    {
      "title": "Request Latency",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(bluerbook_http_request_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Error Responses by Route",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" }, "drawStyle": "bars" } } },
      "targets": [{
        "expr": "sum by (route, status_code) (rate(bluerbook_http_requests_total{status_code=~\"[45]..\"}[$__rate_interval]))",
        "legendFormat": "{{route}} ({{status_code}})"
      }]
    },
    {
      "title": "Latency by Route (p95)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, route) (rate(bluerbook_http_request_duration_seconds_bucket{route=~\"/api/.*\"}[$__rate_interval])))",
        "legendFormat": "{{route}}"
      }]
    },

    {
      "title": "Recipes",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Recipe Operations",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (operation) (rate(bluerbook_recipe_operations_total{}[$__rate_interval]))",
        "legendFormat": "{{operation}}"
      }]
    },
    {
      "title": "Meal Plan Changes",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (action) (rate(bluerbook_meal_plan_changes_total{}[$__rate_interval]))",
        "legendFormat": "{{action}}"
      }]
    },
    {
      "title": "Search Result Size (p50 / p95)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(bluerbook_recipe_search_results_bucket{}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(bluerbook_recipe_search_results_bucket{}[$__rate_interval])))", "legendFormat": "p95" }
      ]
    },
    {
      "title": "Recipe Errors",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 30, "drawStyle": "bars", "stacking": { "mode": "normal" } }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [{
        "expr": "sum by (operation) (rate(bluerbook_recipe_errors_total{}[$__rate_interval]))",
        "legendFormat": "{{operation}}"
      }]
    },

    {
      "title": "Pantry",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Pantry Changes by Action",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (action) (rate(bluerbook_pantry_changes_total{}[$__rate_interval]))",
        "legendFormat": "{{action}}"
      }]
    },
    {
      "title": "Pantry Errors",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 30, "drawStyle": "bars", "stacking": { "mode": "normal" } }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [{
        "expr": "sum by (operation) (rate(bluerbook_pantry_errors_total{}[$__rate_interval]))",
        "legendFormat": "{{operation}}"
      }]
    },

    {
      "title": "Chat / LLM",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Chat Volume",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 49 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15 } } },
      "targets": [
        { "expr": "rate(bluerbook_chat_sessions_created_total{}[$__rate_interval])", "legendFormat": "sessions/s" },
        { "expr": "rate(bluerbook_chat_messages_total{}[$__rate_interval])", "legendFormat": "messages/s" }
      ]
    },
    {
      "title": "Chat Response Latency",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 49 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(bluerbook_chat_response_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(bluerbook_chat_response_duration_seconds_bucket{}[$__rate_interval])))", "legendFormat": "p95" }
      ]
    },
    {
      "title": "Stream Parts per Response",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 49 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(bluerbook_chat_response_stream_parts_bucket{}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(bluerbook_chat_response_stream_parts_bucket{}[$__rate_interval])))", "legendFormat": "p95" }
      ]
    },
    {
      "title": "Chat Errors",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 57 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{
        "expr": "increase(bluerbook_chat_errors_total{}[1h])",
        "legendFormat": "errors (1h)"
      }]
    },

    {
      "title": "Database",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 61 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Query Duration (p95 by query)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, query) (rate(bluerbook_db_query_duration_seconds_bucket{}[$__rate_interval])))",
        "legendFormat": "{{query}}"
      }]
    },
    {
      "title": "Query Rate by Query",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 62 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (query) (rate(bluerbook_db_query_duration_seconds_count{}[$__rate_interval]))",
        "legendFormat": "{{query}}"
      }]
    },
    {
      "title": "Connection Pool",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 70 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 15 } } },
      "targets": [
        { "expr": "go_sql_open_connections{db_name=\"bluerbook\"}", "legendFormat": "open" },
        { "expr": "go_sql_in_use_connections{db_name=\"bluerbook\"}", "legendFormat": "in use" },
        { "expr": "go_sql_idle_connections{db_name=\"bluerbook\"}", "legendFormat": "idle" },
        { "expr": "go_sql_max_open_connections{db_name=\"bluerbook\"}", "legendFormat": "max open" }
      ]
    },
    {
      "title": "Connection Wait",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 70 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "rate(go_sql_wait_count_total{db_name=\"bluerbook\"}[$__rate_interval])", "legendFormat": "waits/s" },
        { "expr": "rate(go_sql_wait_duration_seconds_total{db_name=\"bluerbook\"}[$__rate_interval])", "legendFormat": "wait time/s" }
      ]
    },
    {
      "title": "Query Errors",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 70 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 30, "drawStyle": "bars", "stacking": { "mode": "normal" } }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [{
        "expr": "sum by (query) (rate(bluerbook_db_query_errors_total{}[$__rate_interval]))",
        "legendFormat": "{{query}}"
      }]
    },

    {
      "title": "Go Runtime",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 78 },
      "collapsed": true,
      "panels": [
        {
          "title": "Goroutines & Threads",
          "type": "timeseries",
          "datasource": { "uid": "${datasource}" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 79 },
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 15 } } },
          "targets": [
            { "expr": "go_goroutines{}", "legendFormat": "goroutines" },
            { "expr": "go_threads{}", "legendFormat": "threads" }
          ]
        },
        {
          "title": "Memory",
          "type": "timeseries",
          "datasource": { "uid": "${datasource}" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 79 },
          "fieldConfig": { "defaults": { "unit": "decbytes", "custom": { "fillOpacity": 20 } } },
          "targets": [
            { "expr": "go_memstats_heap_inuse_bytes{}", "legendFormat": "heap in use" },
            { "expr": "process_resident_memory_bytes{}", "legendFormat": "resident" }
          ]
        },
        {
          "title": "GC Pause (p95)",
          "type": "timeseries",
          "datasource": { "uid": "${datasource}" },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 79 },
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
          "targets": [
            { "expr": "go_gc_duration_seconds{quantile=\"0.95\"}", "legendFormat": "p95 pause" }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
